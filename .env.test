# ───────────────────────────────────────────
# Test environment variables
# ───────────────────────────────────────────
# These override VITE_ vars at build time
# and are read by Cypress at runtime

# Backend API URL (empty = all requests mocked via cy.intercept)
VITE_API_URL=

# Cypress configuration overrides
CYPRESS_BASE_URL=http://localhost:5173
CYPRESS_VIDEO=false
CYPRESS_DEFAULT_COMMAND_TIMEOUT=10000
CYPRESS_VIEWPORT_WIDTH=1280
CYPRESS_VIEWPORT_HEIGHT=720

# Coverage
NYC_CAFEOBJECT_COVERAGE=true
