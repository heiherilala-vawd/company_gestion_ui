# ───────────────────────────────────────────
# CI environment overrides
# Copy this to .env.ci and adjust
# ───────────────────────────────────────────

# In Docker the app service is called "app"
CYPRESS_BASE_URL=http://app:5173

# Enable video in CI for debugging failures
CYPRESS_VIDEO=true

# Coverage is always enabled in CI
NYC_CAFEOBJECT_COVERAGE=true
VITE_API_URL=

# Test server port (host mapping, default 5174)
TEST_APP_PORT=5174
