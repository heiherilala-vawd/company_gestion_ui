{
  "all": true,
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules/**",
    "src/gen-ts/**",
    "src/__tests__/**",
    "cypress/**",
    "**/*.d.ts",
    "**/coverage/**",
    "**/dist/**",
    "scripts/**"
  ],
  "reporter": ["text", "html", "lcov"],
  "lines": 60,
  "functions": 60,
  "branches": 60,
  "statements": 60,
  "check-coverage": true,
  "extension": [".ts", ".tsx"]
}
