{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint --fix --ext .js,.jsx,.ts,.tsx ./src",
    "format": "prettier --write ./src",
    "gen:api": "node scripts/generate-api.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cypress:open": "cypress open --config-file src/__tests__/cypress.config.ts",
    "cypress:run": "cypress run --config-file src/__tests__/cypress.config.ts",
    "cypress:coverage": "bash scripts/run-cypress-coverage.sh"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.0.1",
    "@mui/material": "^7.0.1",
    "ra-data-simple-rest": "^5.14.0",
    "react": "^19.0.0",
    "react-admin": "^5.14.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.3",
    "react-router-dom": "^7.1.3"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^4.0.3",
    "@eslint/js": "^9.23.0",
    "@openapitools/openapi-generator-cli": "^2.32.0",
    "@types/node": "^20.10.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "cypress": "^15.14.2",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "nyc": "^18.0.0",
    "prettier": "^3.3.3",
    "serve": "^14.2.6",
    "typescript": "^5.1.6",
    "typescript-eslint": "^8.28.0",
    "vite": "^7.0.0",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "name": "test-admin"
}
